# AI Agent Platform - Nginx 反向代理配置
# 复制到 /etc/nginx/conf.d/ai-platform.conf 后 nginx -s reload 生效
#
# 假设:
#   前端 dist/  部署到 /var/www/ai-platform/dist
#   gateway     跑在 127.0.0.1:9000
#   auth        跑在 127.0.0.1:9001 (lb:// 走 nacos 自动选实例)
#   ...

server {
    listen       80;
    server_name  _;

    # 静态资源
    root   /var/www/ai-platform/dist;
    index  index.html;

    # 前端 SPA 路由 fallback
    location / {
        try_files $uri $uri/ /index.html;
    }

    # ========== 后端 API 代理 (保留 /api 前缀) ==========
    location /api/ {
        proxy_pass         http://127.0.0.1:9000;
        proxy_http_version 1.1;
        proxy_set_header   Host              $host;
        proxy_set_header   X-Real-IP         $remote_addr;
        proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
        proxy_connect_timeout 5s;
        proxy_read_timeout    60s;
        proxy_send_timeout    60s;
    }

    # ========== 静态资源 (avatars / uploads) ==========
    location /uploads/ {
        alias /var/www/ai-platform/uploads/;
        expires 7d;
    }

    # ========== Swagger / Knife4j (可选) ==========
    location /doc.html {
        proxy_pass http://127.0.0.1:9000;
        proxy_set_header Host $host;
    }

    # ========== 错误页 ==========
    error_page 502 503 504 /50x.html;
    location = /50x.html {
        root /usr/share/nginx/html;
    }
}

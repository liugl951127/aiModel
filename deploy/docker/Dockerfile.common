# Compile common module only (used as base for CI/CD)
FROM eclipse-temurin:17-jdk
WORKDIR /workspace
COPY backend/pom.xml .
COPY backend/ai-platform-common/ ai-platform-common/
RUN apt-get update && apt-get install -y maven && rm -rf /var/lib/apt/lists/*
RUN mvn -q -pl ai-platform-common -am install -DskipTests

# 复制: cp .env.example .env
# 生成新 secret: ./scripts/gen-jwt-secret.sh

# JWT 签名密钥 (>= 32 字符, 不能含 'default')
JWT_SECRET=8ce0051f919040db82c8058f74ff20a80fb039c8de194656512a8ea7207552da

# MySQL
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=951127
MYSQL_DB=ai_platform

# Redis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=

# Nacos (可选, dev/test 可关)
NACOS_SERVER=127.0.0.1:8848

# AI Backend: mock / onnx / ollama / http
AI_BACKEND=mock

# ★ OP-12 环境变量模板 (运维经理要求: secrets 跟代码分离)
# 用法: cp .env.example .env, 改密码, source .env 后再部署
# 生产环境推荐用 Vault / Nacos / K8s Secret

# ============ 必填 ============
# JWT 签名密钥 (生成: ./scripts/gen-jwt-secret.sh)
JWT_SECRET=

# ============ MySQL ============
MYSQL_ROOT_PASSWORD=

# ============ Redis ============
REDIS_PASSWORD=

# ============ ES ============
ES_PASSWORD=

# ============ Nacos ============
NACOS_PASSWORD=

# ============ 监控告警 (选填) ============
GRAFANA_PASSWORD=
FEISHU_WEBHOOK_URL=
DINGTALK_WEBHOOK_URL=
WECOM_WEBHOOK_URL=

# ============ 远程备份 (选填) ============
REMOTE_BACKUP_HOST=
REMOTE_BACKUP_USER=

# ============ 部署版本 (build 时注入) ============
VERSION=2.0.20260618
